<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_RZD_Participants" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:dataStore id="DataStore_Main" name="Единая БД РЖД (расписания, брони, платежи, билеты)" />
  <bpmn:error id="Error_SeatUnavailable" name="Ошибка: место уже занято" errorCode="SEAT_UNAVAILABLE" />
  <bpmn:error id="Error_PaymentDeclined" name="Ошибка: оплата отклонена" errorCode="PAYMENT_DECLINED" />
  <bpmn:collaboration id="Collaboration_RZD">
    <bpmn:participant id="Participant_Client" name="Клиент" processRef="Process_Client" />
    <bpmn:participant id="Participant_Server" name="Сервер РЖД" processRef="Process_Server" />
    <bpmn:participant id="Participant_Bank" name="Банк" processRef="Process_Bank" />
    <bpmn:messageFlow id="MF_Client_Search" sourceRef="Task_Client_SendSearchRequest" targetRef="Task_Server_ReceiveSearchRequest" />
    <bpmn:messageFlow id="MF_Server_BankPayment" sourceRef="Task_Server_SendPaymentToBank" targetRef="Task_Bank_Authorize" />
    <bpmn:messageFlow id="MF_Bank_ServerSuccess" sourceRef="Task_Bank_SendSuccessStatus" targetRef="Task_Server_ReceiveBankStatus" />
    <bpmn:messageFlow id="MF_Bank_ServerDecline" sourceRef="Task_Bank_SendDeclineStatus" targetRef="Task_Server_ReceiveBankStatus" />
    <bpmn:messageFlow id="MF_Server_ClientTicket" sourceRef="Task_Server_IssueTicket" targetRef="Task_Client_ReceiveTicket" />
    <bpmn:messageFlow id="Flow_0lsmpyd" sourceRef="Task_Server_ValidateSearch" targetRef="Task_Client_ReceiveTicketTable" />
    <bpmn:messageFlow id="Flow_157iuyz" sourceRef="Task_Client_FilterTable" targetRef="Activity_1dc7k9a" />
    <bpmn:messageFlow id="Flow_0erw54r" sourceRef="Task_Client_ConfirmOrder" targetRef="Task_Server_CheckSeatPrice" />
    <bpmn:messageFlow id="Flow_0vn9tg3" sourceRef="Task_Server_CreateBooking" targetRef="Task_Client_EnterCard" />
    <bpmn:messageFlow id="Flow_0z78mf2" sourceRef="Task_Client_Confirm3DS" targetRef="Task_Server_SendPaymentToBank" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Client" name="Клиент: покупка в ЛК" isExecutable="false">
    <bpmn:startEvent id="Start_Client" name="Вход в личный кабинет">
      <bpmn:outgoing>Flow_C_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Client_OpenLK" name="Открыть форму покупки">
      <bpmn:incoming>Flow_C_1</bpmn:incoming>
      <bpmn:outgoing>Flow_C_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Client_SendSearchRequest" name="Отправить запрос на поиск">
      <bpmn:incoming>Flow_C_3</bpmn:incoming>
    </bpmn:task>
    <bpmn:endEvent id="End_Client_Success" name="Покупка завершена">
      <bpmn:incoming>Flow_C_20</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Client_ReceiveTicket" name="Получить электронный билет">
      <bpmn:outgoing>Flow_C_20</bpmn:outgoing>
    </bpmn:task>
    <bpmn:userTask id="Task_Client_ConfirmOrder" name="Подтвердить заказ">
      <bpmn:incoming>Flow_16vkgsf</bpmn:incoming>
      <bpmn:incoming>Flow_1srb6m2</bpmn:incoming>
    </bpmn:userTask>
    <bpmn:task id="Task_Client_ReceiveTicketTable" name="Получить таблицу билетов">
      <bpmn:outgoing>Flow_C_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:userTask id="Task_Client_FilterTable" name="Фильтрация и сортировка таблицы">
      <bpmn:incoming>Flow_C_5</bpmn:incoming>
      <bpmn:outgoing>Flow_C_6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Client_SelectSeat" name="Выбрать поезд, вагон и место">
      <bpmn:incoming>Flow_C_6</bpmn:incoming>
      <bpmn:outgoing>Flow_C_7</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_0ug5vgb" name="Ввести данные пассажира(email, телефон, паспорт)">
      <bpmn:incoming>Flow_C_7</bpmn:incoming>
      <bpmn:outgoing>Flow_16vkgsf</bpmn:outgoing>
      <bpmn:outgoing>Flow_1srb6m2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Client_EnterCard" name="Ввести данные карты">
      <bpmn:outgoing>Flow_C_15</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Client_Confirm3DS" name="Подтвердить 3-D Secure">
      <bpmn:incoming>Flow_C_15</bpmn:incoming>
    </bpmn:userTask>
    <bpmn:subProcess id="Task_Client_EnterRoute" name="Ввести маршрут, дату и пассажиров">
      <bpmn:incoming>Flow_C_2</bpmn:incoming>
      <bpmn:outgoing>Flow_C_3</bpmn:outgoing>
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_C_1" sourceRef="Start_Client" targetRef="Task_Client_OpenLK" />
    <bpmn:sequenceFlow id="Flow_C_2" sourceRef="Task_Client_OpenLK" targetRef="Task_Client_EnterRoute" />
    <bpmn:sequenceFlow id="Flow_C_3" sourceRef="Task_Client_EnterRoute" targetRef="Task_Client_SendSearchRequest" />
    <bpmn:sequenceFlow id="Flow_C_20" sourceRef="Task_Client_ReceiveTicket" targetRef="End_Client_Success" />
    <bpmn:sequenceFlow id="Flow_16vkgsf" sourceRef="Activity_0ug5vgb" targetRef="Task_Client_ConfirmOrder" />
    <bpmn:sequenceFlow id="Flow_1srb6m2" sourceRef="Activity_0ug5vgb" targetRef="Task_Client_ConfirmOrder" />
    <bpmn:sequenceFlow id="Flow_C_5" sourceRef="Task_Client_ReceiveTicketTable" targetRef="Task_Client_FilterTable" />
    <bpmn:sequenceFlow id="Flow_C_6" sourceRef="Task_Client_FilterTable" targetRef="Task_Client_SelectSeat" />
    <bpmn:sequenceFlow id="Flow_C_7" sourceRef="Task_Client_SelectSeat" targetRef="Activity_0ug5vgb" />
    <bpmn:sequenceFlow id="Flow_C_15" sourceRef="Task_Client_EnterCard" targetRef="Task_Client_Confirm3DS" />
  </bpmn:process>
  <bpmn:process id="Process_Server" name="Сервер РЖД: обработка заказа" isExecutable="true">
    <bpmn:dataStoreReference id="DataStoreRef_Main" name="Единая БД РЖД" dataStoreRef="DataStore_Main" />
    <bpmn:serviceTask id="Task_Server_CheckSeatPrice" name="Проверить место, данные пользователя и актуальную цену">
      <bpmn:incoming>Flow_S_7</bpmn:incoming>
      <bpmn:outgoing>Flow_S_8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:task id="Task_Server_ReceiveSearchRequest" name="Принять запрос поиска">
      <bpmn:outgoing>Flow_S_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Server_SendPaymentToBank" name="Отправить запрос на оплату в банк" />
    <bpmn:task id="Task_Server_ReceiveBankStatus" name="Принять статус оплаты от банка">
      <bpmn:outgoing>Flow_081nt46</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Server_ReceiveOrderConfirm" name="Принять подтверждение заказа">
      <bpmn:outgoing>Flow_S_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="Task_Server_IssueTicket" name="Сформировать электронный билет">
      <bpmn:incoming>Flow_1n58psq</bpmn:incoming>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_088quaf">
        <bpmn:targetRef>DataStoreRef_Main</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Server_UpdatePaymentStatusDB" name="Обновить статус оплаты в БД">
      <bpmn:incoming>Flow_081nt46</bpmn:incoming>
      <bpmn:outgoing>Flow_1vkzlvl</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_0ipe0f6" name="Платеж успешный?" default="Flow_1s90nkc">
      <bpmn:incoming>Flow_1vkzlvl</bpmn:incoming>
      <bpmn:outgoing>Flow_1n58psq</bpmn:outgoing>
      <bpmn:outgoing>Flow_1s90nkc</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Activity_0zr7z9q" name="Отклонить платеж пользователя">
      <bpmn:incoming>Flow_1s90nkc</bpmn:incoming>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Server_ValidateSearch" name="Проверить параметры поиска, собрать таблицу билетов">
      <bpmn:incoming>Flow_S_2</bpmn:incoming>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1tsh3bf">
        <bpmn:targetRef>DataStoreRef_Main</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_1dc7k9a" name="Фильтрация, пагинация, сортировка таблицы">
      <bpmn:dataOutputAssociation id="DataOutputAssociation_0ld16y2">
        <bpmn:targetRef>DataStoreRef_Main</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Server_CreateBooking" name="Создать бронь и платежный ордер">
      <bpmn:incoming>Flow_S_8</bpmn:incoming>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_0vz39m7">
        <bpmn:targetRef>DataStoreRef_Main</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="Event_1bhyr5t" attachedToRef="Task_Server_CheckSeatPrice">
      <bpmn:errorEventDefinition id="ErrorEventDefinition_0b5mxcd" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Event_14dxdte" attachedToRef="Activity_0zr7z9q">
      <bpmn:errorEventDefinition id="ErrorEventDefinition_184ys4u" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_S_7" sourceRef="Task_Server_ReceiveOrderConfirm" targetRef="Task_Server_CheckSeatPrice" />
    <bpmn:sequenceFlow id="Flow_S_8" sourceRef="Task_Server_CheckSeatPrice" targetRef="Task_Server_CreateBooking" />
    <bpmn:sequenceFlow id="Flow_S_2" sourceRef="Task_Server_ReceiveSearchRequest" targetRef="Task_Server_ValidateSearch" />
    <bpmn:sequenceFlow id="Flow_081nt46" sourceRef="Task_Server_ReceiveBankStatus" targetRef="Task_Server_UpdatePaymentStatusDB" />
    <bpmn:sequenceFlow id="Flow_1n58psq" sourceRef="Gateway_0ipe0f6" targetRef="Task_Server_IssueTicket" />
    <bpmn:sequenceFlow id="Flow_1vkzlvl" sourceRef="Task_Server_UpdatePaymentStatusDB" targetRef="Gateway_0ipe0f6" />
    <bpmn:sequenceFlow id="Flow_1s90nkc" sourceRef="Gateway_0ipe0f6" targetRef="Activity_0zr7z9q" />
    <bpmn:association id="Assoc_DB_UpdatePayment" sourceRef="Task_Server_UpdatePaymentStatusDB" targetRef="DataStoreRef_Main" />
  </bpmn:process>
  <bpmn:process id="Process_Bank" name="Банк: обработка платежа" isExecutable="false">
    <bpmn:serviceTask id="Task_Bank_Authorize" name="Проверить карту и 3DS">
      <bpmn:outgoing>Flow_B_3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Bank_Approved" name="Платеж одобрен?" default="Flow_B_No">
      <bpmn:incoming>Flow_B_3</bpmn:incoming>
      <bpmn:outgoing>Flow_B_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_B_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_Bank_CaptureFunds" name="Списать средства">
      <bpmn:incoming>Flow_B_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_1ug9r2z</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:task id="Task_Bank_SendDeclineStatus" name="Отправить статус DECLINED">
      <bpmn:incoming>Flow_B_No</bpmn:incoming>
      <bpmn:incoming>Flow_15ebro6</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="Task_Bank_SendSuccessStatus" name="Отправить статус SUCCESS">
      <bpmn:incoming>Flow_1p58pnh</bpmn:incoming>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_1agj4l7" name="Платеж одобрен?" default="Flow_15ebro6">
      <bpmn:incoming>Flow_1ug9r2z</bpmn:incoming>
      <bpmn:outgoing>Flow_1p58pnh</bpmn:outgoing>
      <bpmn:outgoing>Flow_15ebro6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:boundaryEvent id="Event_19l1kf0" attachedToRef="Task_Bank_Authorize">
      <bpmn:errorEventDefinition id="ErrorEventDefinition_1i7r3xc" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_B_3" sourceRef="Task_Bank_Authorize" targetRef="Gateway_Bank_Approved" />
    <bpmn:sequenceFlow id="Flow_B_Yes" sourceRef="Gateway_Bank_Approved" targetRef="Task_Bank_CaptureFunds">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${bankApproved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_B_No" sourceRef="Gateway_Bank_Approved" targetRef="Task_Bank_SendDeclineStatus" />
    <bpmn:sequenceFlow id="Flow_1ug9r2z" sourceRef="Task_Bank_CaptureFunds" targetRef="Gateway_1agj4l7" />
    <bpmn:sequenceFlow id="Flow_15ebro6" sourceRef="Gateway_1agj4l7" targetRef="Task_Bank_SendDeclineStatus" />
    <bpmn:sequenceFlow id="Flow_1p58pnh" sourceRef="Gateway_1agj4l7" targetRef="Task_Bank_SendSuccessStatus" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_RZD">
    <bpmndi:BPMNPlane id="BPMNPlane_RZD" bpmnElement="Collaboration_RZD">
      <bpmndi:BPMNShape id="Participant_Client_di" bpmnElement="Participant_Client" isHorizontal="true">
        <dc:Bounds x="120" y="120" width="7600" height="340" />
      </bpmndi:BPMNShape>
