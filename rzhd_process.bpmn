        <dc:Bounds x="4695" y="425" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_0f3m77e" bpmnElement="Gateway_0ipe0f6" isMarkerVisible="true">
        <dc:Bounds x="4915" y="440" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="4910" y="406" width="59" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_0eyx9yp_di" bpmnElement="Activity_0zr7z9q">
        <dc:Bounds x="5200" y="530" width="100" height="80" />
